PORT=5001
NODE_ENV=development

# MongoDB
MONGO_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/cambo_rent

# JWT
JWT_SECRET=your-super-secret-key-change-in-production
JWT_EXPIRES_IN=7d

# Stripe (optional – leave empty for mock mode)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# SMTP (optional – logs to console if not configured)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=

# Client URL (for password reset links)
CLIENT_URL=http://localhost:4200
